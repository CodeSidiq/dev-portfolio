'use client';

import { Mail, Menu } from 'lucide-react';
import { motion, useScroll, useTransform } from 'motion/react';
import Image from 'next/image';
import Link from 'next/link';
import React from 'react';

import { Button } from '@/components/ui/button';
import {
  Sheet,
  SheetTrigger,
  SheetContent,
  SheetTitle,
  SheetClose,
} from '@/components/ui/sheet';

import { navigationData } from '@/constants/navigation-data';

const Navbar = () => {
  const { scrollY } = useScroll();
  const background = useTransform(
    scrollY,
    [0, 100],
    [
      'color-mix(in srgb, var(--color-base-background) 0%, transparent)',
      'color-mix(in srgb, var(--color-base-background) 70%, transparent)',
    ]
  );
  const backdropBlur = useTransform(
    scrollY,
    [0, 100],
    ['blur(0px)', 'blur(10px)']
  );

  return (
    <motion.header
      style={{
        background,
        backdropFilter: backdropBlur,
      }}
      className='fixed top-0 z-50 w-full'
    >
      <div className='flex-between custom-container h-16 md:h-21'>
        <Image
          src='/images/logo.svg'
          alt='logo'
          width={158}
          height={56}
          className='h-10 w-10 object-contain max-md:h-8 max-md:w-8'
        />
        <nav className='hidden lg:block'>
          <ul className='flex-start gap-3'>
            {navigationData.map((data) => (
              <li key={data.label}>
                <Link href={data.href} className='hover:text-primary-200 p-4'>
                  {data.label}
                </Link>
              </li>
            ))}
          </ul>
        </nav>
        <Button
          asChild
          className='hidden h-10 gap-2 rounded-full bg-[image:var(--gradient-brand)] px-6 text-base-white shadow-[var(--shadow-brand-glow)] hover:text-base-white lg:flex'
        >
          <Link href='#contact'>
            <Mail className='size-4' aria-hidden='true' />
            Hire Me
          </Link>
        </Button>

        <Sheet>
          <SheetTrigger asChild>
            <Menu className='cursor-pointer lg:hidden' />
          </SheetTrigger>
          <SheetContent>
            <nav className='mt-16'>
              <ul className='flex flex-col gap-4'>
                {navigationData.map((data) => (
                  <li key={data.label}>
                    <SheetClose asChild>
                      <Link
                        href={data.href}
                        className='hover:text-primary-200 py-4'
                      >
                        {data.label}
                      </Link>
                    </SheetClose>
                  </li>
                ))}
              </ul>
            </nav>

            <Button
              asChild
              className='mt-3 w-full gap-2 rounded-full bg-[image:var(--gradient-brand)] text-base-white shadow-[var(--shadow-brand-glow)] hover:text-base-white'
            >
              <SheetClose asChild>
                <Link href='#contact'>
                  <Mail className='size-4' aria-hidden='true' />
                  Hire Me
                </Link>
              </SheetClose>
            </Button>
          </SheetContent>
        </Sheet>
      </div>
    </motion.header>
  );
};

export default Navbar;
